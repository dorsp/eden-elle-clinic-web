# Normalize line endings across Mac/Windows/Linux so git shows no phantom diffs
* text=auto eol=lf

# Keep Windows-specific scripts as CRLF
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
